# Environment Variables for Doujins Billing Service
# Copy this file to .env and fill in your actual values
# See config.example.yaml for detailed documentation of each setting

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Environment: prod, dev, development, production
# Controls logging verbosity and debug features (NOT payment mode)
ENV=development

# Test Mode: Controls whether payment processors use sandbox/test environments
# - true (default): NMI uses sandbox.nmi.com, CCBill uses sandbox-api, Solana uses devnet
# - false: All processors use production endpoints
#
# This is separate from ENV - you can run prod environment with test_mode
# for staging, or dev environment with test_mode=false for local prod testing.
#
# Stripe note: Uses API key prefix (sk_test_* vs sk_live_*) to determine mode.
# If your key doesn't match TEST_MODE, Stripe will be disabled with a warning.
TEST_MODE=true

# =============================================================================
# STANDALONE MODE ONLY
# =============================================================================
# These settings only apply when running doujins-billing as a standalone service.

HOST=0.0.0.0           # Address to bind to (default: 0.0.0.0)
PORT=2053              # Public HTTP/HTTPS port (default: 2053)
PRIVATE_PORT=8060      # Internal/service API port (default: 8060)

# =============================================================================
# BOTH MODES (standalone + embedded)
# =============================================================================

# API URL: Base URL where billing's /v1/* routes are mounted.
# REQUIRED for Solana Pay transaction_request URLs.
#
# Standalone: API_URL=https://api.mysite.com
# Embedded:   API_URL=https://api.mysite.com/billing
#
API_URL=https://api.example.com

# Internal Billing API Key (for server-to-server communication, X-API-KEY header)
BILLING_API_KEY=change-me-in-dev

# CORS Origins (comma-separated for env var, or use config.yaml for array)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# =============================================================================
# STORE/MERCHANT BRANDING
# =============================================================================

# STORE_NAME=My Store                              # Merchant name (default: "My Store")
# STORE_LOGO_URL=https://your-domain.com/logo.png  # Logo URL (default: embedded $ icon)
# STORE_FROM_EMAIL=noreply@your-domain.com         # Sender email for outgoing emails (required if SendGrid configured)
# STORE_BILLING_URL=https://your-domain.com/account # Customer billing settings URL (used in emails)

# =============================================================================
# LOGGING
# =============================================================================

# LOGGER_LEVEL=info  # debug, info, warn, error, fatal, panic (default: info)

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# Option 1: Full connection string (takes precedence if set)
DB_URL=postgres://admin:admin_password@localhost:5432/billing_db?sslmode=disable

# Option 2: Atomic parameters (preferred for Kubernetes/Vault templates)
# If DB_URL is set, these are ignored. Otherwise, connection string is built from these:
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=billing_db
# DB_USERNAME=admin
# DB_PASSWORD=admin_password
# DB_SSLMODE=disable

# =============================================================================
# REDIS
# =============================================================================

# REDIS_ADDR=garnet:6379   # Redis/Garnet address
# REDIS_PASSWORD=          # Redis password (if required)
# REDIS_DB=0               # Redis database number

# =============================================================================
# AUTHENTICATION (JWT Verifier)
# =============================================================================

# Expected audience claim in incoming JWTs
AUTH_EXPECTED_AUDIENCE=billing-app

# Issuers - JSON array of token issuer URLs
# Billing fetches JWKS from each {issuer}/.well-known/jwks.json per OIDC spec
# AUTH_ISSUERS=["http://localhost:8080"]

# =============================================================================
# DEVELOPER TOOLS (OPTIONAL)
# =============================================================================
# Cloudflared tunnel settings (used by `cloudflared`, not by billing).
# Store this in your local shell env / secret manager; do not commit real values.
# Used for deterministic webhook URLs when testing Mobius/NMI sandbox.
# See: docs/cloudflared-webhooks.md and config.example.yaml (cloudflared.*)
#
# Used to run the tunnel:
#   cloudflared tunnel run --token "$CLOUDFLARED_TUNNEL_TOKEN"
CLOUDFLARED_TUNNEL_TOKEN=your-cloudflared-tunnel-token
#
# Convenience metadata for scripts/docs (optional):
CLOUDFLARED_TUNNEL_NAME=billing-webhooks
CLOUDFLARED_PUBLIC_HOSTNAME=billing-webhooks.example.com

# =============================================================================
# PAYMENT PROCESSORS
# =============================================================================
# All processors use: PROCESSORS_<NAME>_<FIELD>
# Example: PROCESSORS_MOBIUS_SECURITY_KEY, PROCESSORS_CCBILL_SALT

# -----------------------------------------------------------------------------
# NMI-backed processors (Mobius, etc.)
# -----------------------------------------------------------------------------
# Pattern: PROCESSORS_<PROVIDER>_<FIELD>
PROCESSORS_MOBIUS_SECURITY_KEY=your-mobius-security-key
PROCESSORS_MOBIUS_TOKENIZATION_KEY=your-mobius-tokenization-key
PROCESSORS_MOBIUS_TOKENIZATION_URL=https://secure.networkmerchants.com/token/Collect.js
PROCESSORS_MOBIUS_WEBHOOK_SECRET=your-mobius-webhook-secret
# PROCESSORS_MOBIUS_DIRECT_POST_URL=https://secure.mobiusgateway.com/api/transact.php
# PROCESSORS_MOBIUS_QUERY_URL=https://secure.mobiusgateway.com/api/query.php

# Example: Another NMI provider (no code changes needed - just add config)
# PROCESSORS_ACME_SECURITY_KEY=your-acme-security-key
# PROCESSORS_ACME_WEBHOOK_SECRET=your-acme-webhook-secret

# -----------------------------------------------------------------------------
# CCBill
# -----------------------------------------------------------------------------
PROCESSORS_CCBILL_SALT=your-ccbill-salt
PROCESSORS_CCBILL_CLIENT_ACC_NUM=your-account-number
PROCESSORS_CCBILL_CLIENT_SUB_ACC=your-subaccount
# PROCESSORS_CCBILL_SUBSCRIPTION_TYPE_ID=0001

# DataLink (for reconciliation)
# PROCESSORS_CCBILL_DATALINK_USERNAME=your-datalink-username
# PROCESSORS_CCBILL_DATALINK_PASSWORD=your-datalink-password

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# PROCESSORS_STRIPE_SECRET_KEY=sk_test_...
# PROCESSORS_STRIPE_WEBHOOK_SECRET=whsec_...
# PROCESSORS_STRIPE_SUCCESS_URL=https://your-domain.com/checkout/success
# PROCESSORS_STRIPE_CANCEL_URL=https://your-domain.com/checkout/cancel

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------
PROCESSORS_SOLANA_RECIPIENT_WALLET=your-solana-wallet-address
# Network is auto-derived from TEST_MODE: devnet if TEST_MODE=true, mainnet otherwise
# PROCESSORS_SOLANA_NETWORK=mainnet  # explicit override (rarely needed)

# RPC Configuration (choose one):
# OPTION 1: Automatic fallback chain (RECOMMENDED)
# Uses: Helius (if configured) → Ankr → Solana public
# Get free Helius API key at https://helius.dev (100k req/day)
# PROCESSORS_SOLANA_HELIUS_API_KEY=your-helius-api-key
#
# OPTION 2: Custom RPC endpoint (bypasses fallback)
# PROCESSORS_SOLANA_RPC_ENDPOINT=https://your-rpc-provider.com

# Token Configuration (choose one):
# OPTION 1: Simple list (RECOMMENDED) - uses Jupiter for metadata lookup
# PROCESSORS_SOLANA_ENABLED_TOKENS=SOL,USDC,PYUSD
# PROCESSORS_SOLANA_ENABLED_TOKENS=SOL,USDC,PYUSD,BONK,JUP  # add more tokens
#
# OPTION 2: Legacy supported_tokens - use config.yaml for full control

# =============================================================================
# ANALYTICS (ClickHouse)
# =============================================================================

# CLICKHOUSE_HTTP_ADDR=http://clickhouse:8123
# CLICKHOUSE_CLIENT_ADDR=clickhouse:9000
# CLICKHOUSE_DB=analytics
# CLICKHOUSE_CLUSTER=billing
CLICKHOUSE_USER=analytics_user
CLICKHOUSE_PASSWORD=analytics_password

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================
# Sender info uses STORE_FROM_EMAIL and STORE_NAME above.

SENDGRID_API_KEY=your-sendgrid-api-key

# =============================================================================
# FEATURE FLAGS (Safety Controls)
# =============================================================================
# These flags control potentially destructive background operations.
# Use them to quickly disable operations when bugs are suspected.

# Dunning Mode: Controls retry charging for failed subscription rebills
# Values:
#   on (default):     Normal dunning - retry charges, grace period, recovery
#   dry_run_only:     Workflow runs but no charges - for debugging
#   off:              No dunning - immediate cancel on rebill failure
#
# FEATURE_FLAGS_DUNNING_MODE=on

# Disable Entitlement Expiration: Stops credits/entitlements from expiring
# When true: CreditExpiryWorker, HoldExpiryWorker, and entitlement revocation pause
# When false (default): Normal expiration behavior
#
# FEATURE_FLAGS_DISABLE_ENTITLEMENT_EXPIRATION=false
