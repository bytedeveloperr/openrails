# Environment Variables for Doujins Billing Service
# Copy this file to .env and fill in your actual values

# Server Configuration
# BILLING_HOST=0.0.0.0  # Host to bind to (default: 0.0.0.0)
# BILLING_PORT=2053     # Public HTTP/HTTPS port (default: 2053)

# Database Configuration
# Option 1: Full connection string (legacy/convenience)
DB_URL="postgres://billing_app:billing_password@localhost:5432/doujins_db?sslmode=disable"

# Option 2: Atomic parameters (preferred for Kubernetes/Vault templates)
# If DB_URL is set, it takes precedence. Otherwise, connection string is built from these:
# DB_HOST=doujins-db-rw.postgres.svc.cluster.local
# DB_PORT=5432
# DB_DATABASE=doujins_db
# DB_USERNAME=billing_app
# DB_PASSWORD=your-secure-password
# DB_SCHEMA=billing
# DB_SSLMODE=disable

# Legacy Database Passwords (set by bootstrap script - deprecated in favor of DB_* above)
BILLING_DB_PASSWORD=billing_password
DOUJINS_DB_PASSWORD=doujins_password

# ClickHouse Credentials
CLICKHOUSE_USER=analytics_user
CLICKHOUSE_PASSWORD=analytics_password

# Authentication Configuration (JWT Verifier)
# Billing is a JWT verifier (not an issuer). It verifies tokens issued by doujins/hentai0.
# AUTH_AUDIENCE: The expected audience claim in the JWT (must be "billing-app")
# BILLING_AUTH_ISSUERS: JSON array of issuer URLs (via BILLING_ prefix, e.g., in Vault)
#                       Billing will fetch JWKS from each {issuer}/.well-known/jwks.json
#                       Example: ["http://localhost:2052", "http://localhost:4000"]
#                       For production: ["https://doujins.com", "https://hentai0.com"]
AUTH_AUDIENCE=billing-app
# Note: AUTH_ISSUERS is typically configured via Vault injection as a JSON array
# For local dev with .env, use config.yaml or BILLING_AUTH_ISSUERS (JSON format)

# CCBill Payment Processor
CCBILL_SALT=your-ccbill-salt
CCBILL_DATALINK_USERNAME=your-datalink-username
CCBILL_DATALINK_PASSWORD=your-datalink-password
CCBILL_DATALINK_CLIENT_ACC_NUM=your-datalink-client-acc-num

# NMI Payment Processor (Mobius)
NMI_MOBIUS_SECURITY_KEY=your-security-key
NMI_MOBIUS_TOKENIZATION_KEY=your-tokenization-key
NMI_MOBIUS_WEBHOOK_SECRET=your-webhook-secret

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# Internal Billing API Key (for server-to-server communication)
BILLING_API_KEY=change-me-in-dev

# Solana Blockchain (optional)
SOLANA_RECIPIENT_WALLET=your-solana-wallet-address
