# Environment Variables for Doujins Billing Service
# Copy this file to .env and fill in your actual values
# See config.example.yaml for detailed documentation of each setting

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Environment: prod, dev, development, production
ENVIRONMENT=development

# =============================================================================
# STANDALONE MODE ONLY
# =============================================================================
# These settings only apply when running doujins-billing as a standalone service.

HOST=0.0.0.0           # Address to bind to (default: 0.0.0.0)
PORT=2053              # Public HTTP/HTTPS port (default: 2053)
PRIVATE_PORT=8060      # Internal/service API port (default: 8060)

# =============================================================================
# BOTH MODES (standalone + embedded)
# =============================================================================

# API URL: Base URL where billing's /v1/* routes are mounted.
# REQUIRED for Solana Pay transaction_request URLs.
#
# Standalone: API_URL=https://api.mysite.com
# Embedded:   API_URL=https://api.mysite.com/billing
#
API_URL=https://api.example.com

# Internal Billing API Key (for server-to-server communication, X-API-KEY header)
BILLING_API_KEY=change-me-in-dev

# CORS Origins (comma-separated for env var, or use config.yaml for array)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# =============================================================================
# STORE/MERCHANT BRANDING
# =============================================================================

# STORE_NAME=My Store                              # Merchant name (default: "My Store")
# STORE_LOGO_URL=https://your-domain.com/logo.png  # Logo URL (default: embedded $ icon)
# STORE_FROM_EMAIL=noreply@your-domain.com         # Sender email for outgoing emails (required if SendGrid configured)

# =============================================================================
# LOGGING
# =============================================================================

# LOGGER_LEVEL=info  # debug, info, warn, error, fatal, panic (default: info)

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# Option 1: Full connection string (takes precedence if set)
DB_URL=postgres://admin:admin_password@localhost:5432/doujins_db?sslmode=disable

# Option 2: Atomic parameters (preferred for Kubernetes/Vault templates)
# If DB_URL is set, these are ignored. Otherwise, connection string is built from these:
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=doujins_db
# DB_USERNAME=admin
# DB_PASSWORD=admin_password
# DB_SSLMODE=disable

# =============================================================================
# REDIS
# =============================================================================

# REDIS_ADDR=garnet:6379   # Redis/Garnet address
# REDIS_PASSWORD=          # Redis password (if required)
# REDIS_DB=0               # Redis database number

# =============================================================================
# AUTHENTICATION (JWT Verifier)
# =============================================================================

# Expected audience claim in incoming JWTs
AUTH_EXPECTED_AUDIENCE=billing-app

# Issuers - JSON array of token issuer URLs
# Billing fetches JWKS from each {issuer}/.well-known/jwks.json per OIDC spec
# AUTH_ISSUERS=["http://localhost:2052","http://localhost:4000"]

# =============================================================================
# PAYMENT PROCESSORS
# =============================================================================

# -----------------------------------------------------------------------------
# CCBill
# -----------------------------------------------------------------------------
CCBILL_SALT=your-ccbill-salt
CCBILL_CLIENT_ACC_NUM=your-account-number
CCBILL_CLIENT_SUB_ACC=your-subaccount
# CCBILL_SUBSCRIPTION_TYPE_ID=0001
# CCBILL_TEST_MODE=true

# DataLink (for reconciliation)
# CCBILL_DATALINK_USERNAME=your-datalink-username
# CCBILL_DATALINK_PASSWORD=your-datalink-password

# -----------------------------------------------------------------------------
# NMI / Mobius
# -----------------------------------------------------------------------------
# NMI_TEST_MODE=true

# Global NMI settings (can be overridden per-provider)
# NMI_SECURITY_KEY=your-security-key
# NMI_TOKENIZATION_KEY=your-tokenization-key
# NMI_WEBHOOK_SECRET=your-webhook-secret
# NMI_DIRECT_POST_URL=https://secure.networkmerchants.com/api/transact.php
# NMI_QUERY_URL=https://secure.nmi.com/api/query.php

# Per-provider settings (recommended)
NMI_PROVIDERS_MOBIUS_SECURITY_KEY=your-mobius-security-key
NMI_PROVIDERS_MOBIUS_TOKENIZATION_KEY=your-mobius-tokenization-key
NMI_PROVIDERS_MOBIUS_WEBHOOK_SECRET=your-mobius-webhook-secret
# NMI_PROVIDERS_MOBIUS_DIRECT_POST_URL=https://secure.mobiusgateway.com/api/transact.php
# NMI_PROVIDERS_MOBIUS_QUERY_URL=https://secure.mobiusgateway.com/api/query.php

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://your-domain.com/checkout/success
# STRIPE_CANCEL_URL=https://your-domain.com/checkout/cancel

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------
SOLANA_RECIPIENT_WALLET=your-solana-wallet-address
# SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
# SOLANA_NETWORK=mainnet  # mainnet, devnet, testnet
# SOLANA_TRANSACTION_TIMEOUT_SECONDS=300
# SOLANA_CONFIRMATION_BLOCKS=1
# SOLANA_MAX_TRANSACTION_FEE=0.01

# =============================================================================
# ANALYTICS (ClickHouse)
# =============================================================================

# CLICKHOUSE_HTTP_ADDR=http://clickhouse:8123
# CLICKHOUSE_CLIENT_ADDR=clickhouse:9000
# CLICKHOUSE_DATABASE=analytics
# CLICKHOUSE_CLUSTER=doujins
CLICKHOUSE_USER=analytics_user
CLICKHOUSE_PASSWORD=analytics_password

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================
# Sender info uses STORE_FROM_EMAIL and STORE_NAME above.

SENDGRID_API_KEY=your-sendgrid-api-key
