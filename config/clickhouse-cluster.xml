<clickhouse>
    <!-- Single-node cluster for local development -->
    <!-- Requires ClickHouse Keeper for ON CLUSTER DDL coordination -->

    <!-- Macros for ReplicatedMergeTree table paths -->
    <macros>
        <shard>1</shard>
        <replica>replica1</replica>
        <cluster>billing</cluster>
    </macros>

    <remote_servers>
        <billing>
            <shard>
                <replica>
                    <host>localhost</host>
                    <port>9000</port>
                </replica>
            </shard>
        </billing>
    </remote_servers>

    <!-- ClickHouse Keeper connection for distributed DDL -->
    <zookeeper>
        <node>
            <host>clickhouse-keeper</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Enable distributed DDL (ON CLUSTER) support -->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
</clickhouse>
